aws_region = "eu-west-1"
name       = "stackd"

# Optional: custom domain (recommended — see README bootstrap section)
# domain_name     = "stackd.acme.com"
# route53_zone_id = "Z1234567890ABC"

# Google OIDC — create an app at console.cloud.google.com/apis/credentials
# Register the redirect URI from output.google_oauth_redirect_uri before setting these.
# google_client_id       = "123456789-abc.apps.googleusercontent.com"
# google_client_secret   = "GOCSPX-..."
# google_allowed_domains = "acme.com"

# Worker pool token — generate in the Stackd UI after first login, then re-apply.
# worker_pool_token = "wpt_..."
