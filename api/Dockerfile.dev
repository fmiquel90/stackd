# Dev image: hot-reload API via uv (DEV §2). Source is bind-mounted by compose.
FROM python:3.13-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# git is required API-side for repo reachability checks (check_repo) and staleness polling
# (ls_remote_sha, §9.6). safe.directory must live in system config — git ignores `-c` for it — so
# the `file:///stackd-dev/repos/*` dev fixtures don't trip "detected dubious ownership".
RUN apt-get update \
    && apt-get install -y --no-install-recommends git ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && git config --system --add safe.directory '*'

ENV UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/opt/venv \
    PATH=/opt/venv/bin:$PATH

WORKDIR /app

# Install deps first for layer caching; source is mounted at runtime.
COPY pyproject.toml uv.lock* ./
RUN uv sync --frozen --no-install-project 2>/dev/null || uv sync --no-install-project

COPY . .
RUN uv sync --no-editable 2>/dev/null || true

EXPOSE 8000
CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
