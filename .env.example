# Stackd — dev environment. Copied to .env by `task env` (secrets generated into .dev/).
STACKD_ENV=development
STACKD_LOG_FORMAT=json
STACKD_LOG_LEVEL=INFO   # DEBUG also captures reads/polls/heartbeats

# Database (PostgreSQL 18)
DATABASE_URL=postgresql+asyncpg://stackd:stackd@postgres:5432/stackd

# Crypto / sessions — generated by scripts/bootstrap-env.sh on first run
STACKD_ENCRYPTION_KEY=
STACKD_JWT_SECRET=

# Auth
STACKD_DEV_AUTH=true
STACKD_ALLOWED_DOMAINS=dev.local
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
STACKD_PUBLIC_URL=http://localhost:8000
STACKD_APP_URL=http://localhost:5173   # SPA base — used for deep links in outbound notifications

# Object storage (Garage S3)
S3_ENDPOINT_URL=http://garage:3900
S3_BUCKET=stackd
S3_ACCESS_KEY=
S3_SECRET_KEY=
AWS_REGION=garage

# Dev timings (shortened — DEV §8)
STACKD_HEARTBEAT_INTERVAL=5
STACKD_WORKER_OFFLINE_SECONDS=15
STACKD_HEAD_POLL_INTERVAL=15
STACKD_APPLY_AFFINITY_SECONDS=10
